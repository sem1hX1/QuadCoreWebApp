# SourceFlow AI — Frontend Ortam Değişkenleri (Örnek)
# ─────────────────────────────────────────────────────────────────────────────
# Bu dosyayı .env olarak kopyalayın ve kendi ortamınıza göre düzenleyin.
# ─────────────────────────────────────────────────────────────────────────────

# Backend API adresi (FastAPI sunucusu)
VITE_API_URL=http://localhost:8000

# Mock modu (true = backend olmadan çalış, false = backend'e bağlan)
VITE_USE_MOCK=true
